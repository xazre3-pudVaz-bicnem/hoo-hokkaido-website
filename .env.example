# ============================================
# HOO Webサイト 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください。
# APIキーは絶対にコードやGitにコミットしないでください。
# ============================================

# --- サイトURL（本番ドメイン）---
# canonical・OGP・sitemap.xml の生成に使用します。
NEXT_PUBLIC_SITE_URL=https://www.hoohokkaido.com

# --- メール送信（Resend）---
# https://resend.com でAPIキーを取得して設定してください。
# 未設定の場合、フォームは送信エラーになります（サイト自体はクラッシュしません）。
RESEND_API_KEY=

# 送信先メールアドレス（省略時: info@hoohokkaido.com）
MAIL_TO=info@hoohokkaido.com

# 送信元（Resendで独自ドメイン認証後に変更してください）
# 例: HOO Website <noreply@hoohokkaido.com>
MAIL_FROM=HOO Website <onboarding@resend.dev>

# --- Googleマップ埋め込み ---
# Googleマップ →「共有」→「地図を埋め込む」のiframeのsrc URLを設定します。
# 未設定でも画面は崩れません（住所と外部リンクを表示）。
NEXT_PUBLIC_GOOGLE_MAP_EMBED_URL=

# --- コラム記事の翻訳支援（Claude API）---
# `npm run translate:content` を使うときだけ必要です。
# サイトの閲覧時に翻訳APIを呼び出すことはありません（翻訳は事前に実行し、静的ファイルとして保存します）。
# https://console.anthropic.com でAPIキーを取得してください。
ANTHROPIC_API_KEY=

# 使用モデル（省略時: claude-opus-4-8）
ANTHROPIC_MODEL=claude-opus-4-8
